<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1A1D27"
            app:cardCornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#E2E8F0"
                    android:text="Name" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_status_chip" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Details card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1D27"
            app:cardCornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <include layout="@layout/detail_row" android:id="@+id/row_plot"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <!-- Individual rows -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Plot Number" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="12dp"/>
                <TextView android:id="@+id/tv_plot_number" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="16sp" android:layout_marginTop="2dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Section / Block" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="12dp"/>
                <TextView android:id="@+id/tv_section" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="16sp" android:layout_marginTop="2dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Marker Name" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="12dp"/>
                <TextView android:id="@+id/tv_marker_name" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="16sp" android:layout_marginTop="2dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2E3250" android:layout_marginVertical="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Date of Birth" android:textColor="#94A3B8" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_birth_date" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="16sp" android:layout_marginTop="2dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Date of Death" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="12dp"/>
                <TextView android:id="@+id/tv_death_date" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="16sp" android:layout_marginTop="2dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Burial Date" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="12dp"/>
                <TextView android:id="@+id/tv_burial_date" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="16sp" android:layout_marginTop="2dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2E3250" android:layout_marginVertical="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Notes" android:textColor="#94A3B8" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_notes" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="#E2E8F0" android:textSize="15sp"
                    android:layout_marginTop="4dp" android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
