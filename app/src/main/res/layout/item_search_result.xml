<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/card_transparent"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top row: dot + name + map icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/status_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0" />

            <TextView
                android:id="@+id/tv_plot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_dates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Find on Map icon button -->
        <ImageButton
            android:id="@+id/btn_find_map"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_dialog_map"
            android:background="@drawable/card_transparent"
            android:tint="#9e9e9e"
            android:contentDescription="Find on Map"
            android:padding="6dp" />

    </LinearLayout>

    <!-- Hint text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap for details  ·  Map icon to locate"
        android:textSize="10sp"
        android:textColor="#4a4a4a"
        android:layout_marginTop="6dp" />

</LinearLayout>
